{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2022",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "bundler",
		"importHelpers": true,
		"isolatedModules": true,
		"ignoreDeprecations": "6.0",
		"strictNullChecks": true,
		"strict": false,
		"allowSyntheticDefaultImports": true,
		"lib": ["DOM", "ES2022"]
	},
	"include": ["**/*.ts"],
	"exclude": ["node_modules", "tests/"]
}
